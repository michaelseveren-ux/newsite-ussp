---
import { certifications, brands } from '../data/partners';
---

<section class="py-16 bg-white">
  <div class="container-custom">

    <!-- Section Header -->
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-primary-900 mb-3">Certifications & Brand Partners</h2>
      <p class="text-gray-600 max-w-2xl mx-auto">
        Factory-authorized and industry-connected — we work with the brands that matter in sport aviation.
      </p>
    </div>

    <!-- Official Certifications -->
    <div class="mb-12">
      <p class="text-xs font-semibold uppercase tracking-widest text-gray-400 text-center mb-6">Official Certifications</p>
      <div class="flex flex-col sm:flex-row justify-center gap-6">
        {certifications.map((cert) => (
          <div class="flex items-start gap-5 bg-gray-50 border border-gray-200 rounded-xl p-6 flex-1 max-w-sm">
            <div class="flex-shrink-0 w-16 h-16 bg-white rounded-lg border border-gray-200 flex items-center justify-center overflow-hidden">
              <img
                src={cert.logo}
                alt={`${cert.name} logo`}
                class="w-full h-full object-contain p-1"
                onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
              />
              <span
                class="text-xs font-bold text-primary-900 text-center leading-tight px-1 hidden"
                style="display:none"
              >
                {cert.name}
              </span>
            </div>
            <div>
              <p class="text-xs font-semibold text-accent-500 uppercase tracking-wide mb-0.5">{cert.name}</p>
              <h3 class="font-bold text-primary-900 text-base mb-1">{cert.credential}</h3>
              <p class="text-sm text-gray-600 leading-snug">{cert.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Divider -->
    <div class="relative mb-10">
      <div class="absolute inset-0 flex items-center">
        <div class="w-full border-t border-gray-200"></div>
      </div>
      <div class="relative flex justify-center">
        <span class="px-4 bg-white text-xs font-semibold uppercase tracking-widest text-gray-400">
          Brands We Represent
        </span>
      </div>
    </div>

    <!-- Brand Logo Strip -->
    <div class="flex flex-wrap justify-center items-center gap-8 md:gap-12">
      {brands.map((brand) => (
        <a
          href={brand.href}
          target={brand.external ? '_blank' : undefined}
          rel={brand.external ? 'noopener noreferrer' : undefined}
          class="group flex items-center justify-center w-32 h-16 grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all duration-200"
          aria-label={brand.name}
        >
          <img
            src={brand.logo}
            alt={`${brand.name} logo`}
            class="max-w-full max-h-full object-contain"
            onerror="this.style.display='none';this.nextElementSibling.style.display='block'"
          />
          <span
            class="text-sm font-semibold text-gray-500 group-hover:text-primary-900 transition-colors hidden"
            style="display:none"
          >
            {brand.name}
          </span>
        </a>
      ))}
    </div>

  </div>
</section>
